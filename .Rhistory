# 1. Update Plot A (Replacing dotplot with jitter)
Plot_A <- ggplot(microclimate_shield_total_day,
aes(x = factor(midshield, levels = c('present', 'absent')),
y = max_T2_95, color = midshield, fill = midshield)) +
geom_violin(alpha = 0.2, width = 0.6, color = NA) +
# Using jitter instead of dotplot to avoid the "binned" look
geom_jitter(width = 0.15, alpha = 0.3) +
stat_summary(fun = mean, geom = "point", size = 4, shape = 16) +
stat_summary(fun.data = mean_cl_normal, geom = "errorbar", width = 0.2) +
labs(x = "Shield Configuration", y = "Max Temp (°C) at 1 cm (11:00 - 17:00)") +
scale_x_discrete(labels = c("present" = "Present", "absent" = "Absent")) +
scale_color_manual(values = shield_colors) +
scale_fill_manual(values = shield_colors) +
theme_minimal() +
theme(
text = element_text(family = "Arial", size = 16),
axis.title.y = element_text(margin = margin(r = 10)),
legend.position = "none",
panel.grid.major.x = element_blank()
)
# 2. Update Plot B (Matching Plot A's style)
