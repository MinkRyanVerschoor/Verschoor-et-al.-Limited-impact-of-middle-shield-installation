aes(x = factor(midshield, levels = c('present', 'absent')),
y = min_T2_05, color = midshield, fill = midshield)) +
geom_violin(alpha = 0.2, width = 0.6, color = NA) +
geom_jitter(width = 0.15, alpha = 0.3) +
stat_summary(fun = mean, geom = "point", size = 4, shape = 16) +
stat_summary(fun.data = mean_cl_normal, geom = "errorbar", width = 0.2) +
labs(x = "Shield Configuration", y = "Min Temp (°C) at 1 cm (23:00 - 05:00)") +
