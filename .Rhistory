# Chunk 11: Helper function
## --- 1. Enhanced Sensitivity Analysis Function ---
run_sensitivity <- function(base_model, target_vars, data, period_label, ...) {
model_results_list <- list()
for (var in target_vars) {
message(paste0("Running sensitivity analysis for: ", var, " (", period_label, ")"))
# Dynamically update the formula while keeping random effects and interactions
new_formula <- update.formula(formula(base_model), as.formula(paste(var, "~ .")))
# Update the model with speed arguments (...)
mod <- update(base_model, formula = new_formula, newdata = data, ...)
# Save RDS for archival
saveRDS(mod, file = here("data", paste0("m_", var, "_", period_label, ".rds")))
# Extract fixed effects for the comparison plots
res <- broom.mixed::tidy(mod, effects = "fixed", conf.int = TRUE) %>%
mutate(model_label = var)
model_results_list[[var]] <- res
}
return(bind_rows(model_results_list))
}
## --- 2. Master Helper Function ---
process_model_group <- function(base_model, target_vars, data, label, group_name, ...) {
# --- A. Standard Density PP-Check ---
pp_dens <- pp_check(base_model, ndraws = 100) +
labs(
x = "Temperature (°C)",
y = "Probability Density",
title = paste("Distribution Check:", group_name),
subtitle = "Observed data (y) vs. 100 model simulations (y_rep)"
) +
theme_bw() +
theme(axis.title = element_text(face = "bold"), plot.title = element_text(hjust = 0.5))
ggsave(here("data", "figures", paste0("pp_check_", label, ".png")), pp_dens, width = 7, height = 5)
# --- B. LOO-PIT QQ-Plot (Calibration Check) ---
# Requires library(loo)
pp_qq <- pp_check(base_model, type = "loo_pit_qq") +
labs(
title = paste("Calibration Check (LOO-PIT):", group_name),
subtitle = "Assessing predictive distribution calibration (Uniformity)",
x = "Theoretical Uniform Quantiles",
y = "Sample Data Quantiles"
) +
theme_bw() +
theme(axis.title = element_text(face = "bold"), plot.title = element_text(hjust = 0.5))
ggsave(here("data", "figures", paste0("pp_qq_", label, ".png")), pp_qq, width = 7, height = 5)
# --- C. Run Sensitivity Loop ---
all_results <- run_sensitivity(base_model, target_vars, data, label, ...)
# --- D. Extract Main Model Results (Fixed + Hyperparameters) ---
# Including 'ran_pars' ensures we get sd(Intercept) for Date, Wall distance, etc.
base_res_fixed <- broom.mixed::tidy(base_model, effects = "fixed", conf.int = TRUE) %>%
mutate(model_label = "Base (95th)")
# We return a list containing the full tidy results for tables AND the combined results for plots
return(list(
plot_data = bind_rows(all_results, base_res_fixed),
full_table = broom.mixed::tidy(base_model, effects = c("fixed", "ran_pars"), conf.int = TRUE)
))
}
